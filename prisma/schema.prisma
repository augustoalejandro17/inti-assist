// Prisma Schema for Inti-Assist
// Fitness/Nutrition tracking bot with AI
// Database: MongoDB Atlas

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MODEL
// Stores Telegram user information and preferences
// ============================================
model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  telegramId String   @unique @map("telegram_id")
  username   String?
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")

  // Onboarding & Profile
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  age                 Int?
  activityLevel       String?  @map("activity_level")
  goals               String?
  mealsPerDay         Int?     @map("meals_per_day")
  mealTimes           Json?    @map("meal_times")
  reminderTimes       Json?    @map("reminder_times")

  // General settings
  settings     Json     @default("{}")
  timezone     String   @default("UTC")
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  chatLogs ChatLog[]
  metrics  Metric[]

  @@map("users")
}

// ============================================
// CHAT LOG MODEL
// Stores conversation history for context
// ============================================
model ChatLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @map("user_id") @db.ObjectId
  message    String
  response   String
  intent     String?
  rawPayload Json?    @map("raw_payload")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("chat_logs")
}

// ============================================
// METRIC MODEL
// Stores fitness and nutrition metrics
// ============================================
model Metric {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @map("user_id") @db.ObjectId
  category  String
  name      String
  value     Float
  unit      String
  details   Json?
  loggedAt  DateTime @default(now()) @map("logged_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([loggedAt])
  @@map("metrics")
}
